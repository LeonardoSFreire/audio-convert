# Configurações do Audio Converter API

# API Key para autenticação
API_KEY=sk-audio-converter-sua-chave-secreta

# Tamanho máximo do arquivo em MB
MAX_FILE_SIZE=100

# Habilitar cache de conversões
CACHE_ENABLED=true

# Bitrate padrão (64k, 128k, 192k, 256k, 320k)
DEFAULT_BITRATE=128k

# Sample rate padrão (22050, 44100, 48000)
DEFAULT_SAMPLE_RATE=44100

# ============================================
# CONFIGURAÇÕES S3/MINIO (Opcional)
# ============================================

# Habilitar upload para S3/MinIO
S3_ENABLED=true

# Endpoint do S3/MinIO (ex: https://s3.iasolution.app)
S3_ENDPOINT=https://s3.iasolution.app

# Access Key e Secret Key
S3_ACCESS_KEY=seu-access-key
S3_SECRET_KEY=seu-secret-key

# Nome do bucket (será criado automaticamente se não existir)
S3_BUCKET=audio-converter

# Região (padrão: us-east-1)
S3_REGION=us-east-1

# URL pública para acessar arquivos (ex: https://minio.iasolution.app/audio-converter)
# Se não definida, usará: {S3_ENDPOINT}/{S3_BUCKET}
S3_PUBLIC_URL=https://minio.iasolution.app/audio-converter

# Tempo de vida dos arquivos em dias (serão deletados automaticamente após esse período)
S3_LIFETIME_DAYS=5